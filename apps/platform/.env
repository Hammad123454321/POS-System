POS_IN_DOUBT_STALE_MINUTES=15

FISERV_BLUEPAY_ACCOUNT_ID=
FISERV_BLUEPAY_USER_ID=
FISERV_BLUEPAY_SECRET_KEY=
FISERV_BLUEPAY_HASH_TYPE=HMAC_SHA256
