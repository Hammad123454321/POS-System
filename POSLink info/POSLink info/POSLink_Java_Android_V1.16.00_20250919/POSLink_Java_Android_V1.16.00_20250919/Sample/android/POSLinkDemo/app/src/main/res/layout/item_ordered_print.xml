<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              xmlns:tools="http://schemas.android.com/tools"
    >

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:maxWidth="320px"
        android:layout_height="wrap_content"
        tools:text="name1234567890123456789012345678901234567890"
        android:layout_marginTop="@dimen/d38"
        android:layout_marginRight="@dimen/d41"
        style="@style/PrintTextSmallStyle"
        />


    <TextView
        android:id="@+id/tv_number"
        android:layout_width="@dimen/d40"
        android:layout_height="wrap_content"
        tools:text="count"
        android:layout_alignParentRight="true"
        android:layout_marginRight="@dimen/d42"
        android:gravity="center_horizontal"
        android:layout_marginTop="@dimen/d38"
        style="@style/PrintTextSmallStyle"
        />

    <TextView
        android:id="@+id/tv_price"
        android:layout_width="@dimen/d43"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        tools:text="%9.00"
        android:gravity="right"
        android:layout_marginRight="@dimen/d38"
        android:layout_marginTop="@dimen/d38"
        style="@style/PrintTextSmallStyle"
        />

</RelativeLayout>