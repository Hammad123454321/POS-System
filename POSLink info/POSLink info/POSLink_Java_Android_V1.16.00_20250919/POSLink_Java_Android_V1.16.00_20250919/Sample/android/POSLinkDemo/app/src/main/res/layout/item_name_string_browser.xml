<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:gravity="center_vertical"
              android:orientation="horizontal"
    >

    <com.pax.poslink.widget.AlwaysMarqueeTextView
        android:id="@+id/name_txt"
        android:gravity="center_vertical"
        style="@style/request_text"
        tools:text="Text"
        android:text="@string/manage_request_name_null"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="horizontal"
        >

        <EditText
            android:id="@+id/string_val_txt"
            style="@style/request_edit"/>

        <Button
            android:id="@+id/request_browser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="marquee"
            android:singleLine="true"
            android:textSize="12sp"
            android:text="@string/file_browser"/>

    </LinearLayout>



</LinearLayout>
