<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:gravity="center_vertical"
              android:orientation="horizontal"
    >

    <com.pax.poslink.widget.AlwaysMarqueeTextView
        android:id="@+id/name_txt"
        style="@style/request_text"
        android:gravity="center|left"
        android:text="@string/manage_request_timeOut"/>

    <RelativeLayout
        android:layout_width="0.0px"
        android:layout_height="wrap_content"
        android:layout_weight="2">

        <EditText
            android:id="@+id/string_val_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_select"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:textAppearance="?android:attr/textAppearanceSmallInverse"/>

        <TextView
            android:id="@+id/txt_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/string_val_txt"
            android:layout_alignRight="@id/string_val_txt"
            android:layout_alignTop="@id/string_val_txt"
            android:layout_marginRight="7.0dp"
            android:gravity="center_vertical"
            android:text="@string/manage_request_timeOutUnit"
            android:textColor="@android:color/black"
            android:textStyle="bold"/>
    </RelativeLayout>

</LinearLayout>
