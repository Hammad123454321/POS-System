<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sigDetail_linear"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="10dip"
    android:addStatesFromChildren="true">

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0.0px"
        android:layout_weight="1">
        <TableRow android:layout_weight="1"
            android:gravity="center">
            <com.pax.poslink.widget.AlwaysMarqueeTextView
                style="@style/response_text"
                android:text="@string/sigDetail_sigFilePath" />
            <TextView
                android:id="@+id/sigDetail_sigFilePath"
                style="@style/response_edit"
                android:layout_weight="2"/>
            <Button
                android:id="@+id/sigDetail_returnBack"
                android:layout_width="0.0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/sigDetail_returnBack"
                android:textColor="@android:color/black"
                android:textStyle="bold" />
        </TableRow>

        <TableRow android:layout_weight="1"
            android:gravity="center">
            <com.pax.poslink.widget.AlwaysMarqueeTextView
                style="@style/response_text"
                android:text="@string/sigDetail_bmpFilePath" />

            <com.pax.poslink.widget.AlwaysMarqueeTextView
                android:id="@+id/sigDetail_bmpFilePath"
                style="@style/response_edit"/>
            <Button
                android:id="@+id/sigDetail_bmpBrowser"
                android:layout_width="0.0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/file_browser"
                android:textColor="@android:color/black"
                android:textStyle="bold" />
            <Button
                android:id="@+id/sigDetail_bmpSaveBtn"
                android:layout_width="0.0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/sigDetail_bmpSaveBtn"
                android:textColor="@android:color/black"
                android:textStyle="bold" />
        </TableRow>
    </TableLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="5.0px"
        android:layout_marginTop="10dip"
        android:background="@drawable/line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0.0px"
        android:layout_weight="2"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0.0px"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">
            <com.pax.poslink.widget.AlwaysMarqueeTextView
                style="@style/response_text"
                android:layout_width="match_parent"
                android:layout_height="0.0px"
                android:layout_weight="1"
                android:text="@string/sigDetail_sigData"
                android:textColorHighlight="@color/solid_green"
                android:gravity="center|left"/>

            <TextView
                android:id="@+id/sigDetail_sigData"
                style="@style/request_edit_special"
                android:layout_width="match_parent"
                android:layout_height="0.0px"
                android:layout_weight="2"
                android:scrollbars="vertical"
                android:layout_marginLeft="20dip"
                android:layout_marginBottom="20dip"
                android:layout_marginRight="10dip"/>
        </LinearLayout>


        <ImageView
            android:id="@+id/line1"
            android:layout_width="5.0px"
            android:layout_height="match_parent"
            android:background="@drawable/shadow" />

        <LinearLayout
            android:layout_width="0.0px"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">
            <com.pax.poslink.widget.AlwaysMarqueeTextView
                style="@style/response_text"
                android:layout_width="match_parent"
                android:layout_height="0.0px"
                android:layout_weight="1"
                android:text="@string/sigDetail_showImage"
                android:gravity="center|left"/>

            <ImageView
                android:id="@+id/sigDetail_showImage"
                style="@style/request_edit_special"
                android:layout_width="match_parent"
                android:layout_height="0.0px"
                android:layout_weight="2"
                android:layout_marginLeft="20dip"
                android:layout_marginBottom="20dip"
                android:scaleType="fitCenter"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>