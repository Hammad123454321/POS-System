<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:id="@+id/request_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.pax.poslink.widget.AlwaysMarqueeTextView
            android:id="@+id/text_request"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="@string/request"
            android:textColor="@android:color/black"
            android:textStyle="bold"/>

        <Button
            android:visibility="gone"
            android:id="@+id/setPED_btn"
            android:layout_width="100dp"
            android:layout_toRightOf="@+id/text_request"
            android:layout_marginStart="10dp"
            android:layout_height="wrap_content"
            android:textAllCaps="false"
            android:text="SetPED" />

        <Button
            android:id="@+id/process_btn"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:textAllCaps="false"
            tools:text="@string/btn_process" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/line"
            android:layout_below="@id/process_btn"/>
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/request_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>