<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/payment_extData_cashier_linear"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="10dip"
    android:addStatesFromChildren="true">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TableRow>

                    <com.pax.poslink.widget.AlwaysMarqueeTextView
                        style="@style/request_text"
                        android:text="@string/payment_ext_shiftId" />

                    <EditText
                        android:id="@+id/payment_ext_shiftId"
                        style="@style/request_edit" />
                </TableRow>
        </TableLayout>
    </ScrollView>
</LinearLayout>
