<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="25dp"
                android:gravity="center"
                android:text="Sign Data"
                android:textColor="@android:color/black"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_sign_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="150dp"
                android:padding="10dp"
                android:textColor="@android:color/black"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/img_sign"
                android:layout_width="400dp"
                android:layout_height="150dp"
                android:layout_gravity="center" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Alignment :"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <Spinner
                    android:id="@+id/sp_alignment"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2" />

            </LinearLayout>

            <Button
                android:id="@+id/dialog_btn_to_sign"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:drawable/btn_default_small"
                android:text="DisPlay Sign"
                android:textSize="13sp" />

            <Button
                android:id="@+id/dialog_print_btn"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:drawable/btn_default_small"
                android:text="Print Sign"
                android:textSize="13sp" />

            <Button
                android:id="@+id/dialog_print_btn_bitmap"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@android:drawable/btn_default_small"
                android:text="Print Bitmap"
                android:textSize="13sp" />

            <include layout="@layout/layout_print" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>