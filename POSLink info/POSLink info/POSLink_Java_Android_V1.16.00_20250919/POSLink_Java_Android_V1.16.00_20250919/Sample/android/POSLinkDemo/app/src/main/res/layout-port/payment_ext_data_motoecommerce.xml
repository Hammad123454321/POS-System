<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/payment_extData_MOTOEcommerce_linear"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="10dip"
    android:addStatesFromChildren="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableRow>

                <com.pax.poslink.widget.AlwaysMarqueeTextView
                    style="@style/request_text"
                    android:text="@string/payment_ext_MOTOECommerceMode" />

                <EditText
                    android:id="@+id/payment_ext_MOTOECommerceMode"
                    style="@style/request_edit" />
            </TableRow>

            <TableRow>

                <com.pax.poslink.widget.AlwaysMarqueeTextView
                    style="@style/request_text"
                    android:text="@string/payment_ext_MOTOECommerceTransType" />

                <EditText
                    android:id="@+id/payment_ext_MOTOECommerceTransType"
                    style="@style/request_edit" />
            </TableRow>

            <TableRow>

                <com.pax.poslink.widget.AlwaysMarqueeTextView
                    style="@style/request_text"
                    android:text="@string/payment_ext_ECommerceSecureType" />

                <EditText
                    android:id="@+id/payment_ext_ECommerceSecureType"
                    style="@style/request_edit" />
            </TableRow>

            <TableRow>

                <com.pax.poslink.widget.AlwaysMarqueeTextView
                    style="@style/request_text"
                    android:text="@string/payment_ext_MOTOECommerceOrderNum" />

                <EditText
                    android:id="@+id/payment_ext_MOTOECommerceOrderNum"
                    style="@style/request_edit" />
            </TableRow>

            <TableRow>

                <com.pax.poslink.widget.AlwaysMarqueeTextView
                    style="@style/request_text"
                    android:text="@string/payment_ext_installment" />

                <EditText
                    android:id="@+id/payment_ext_installment"
                    style="@style/request_edit" />
            </TableRow>

            <TableRow>

                <com.pax.poslink.widget.AlwaysMarqueeTextView
                    style="@style/request_text"
                    android:text="@string/payment_ext_currentInstallment" />

                <EditText
                    android:id="@+id/payment_ext_currentInstallment"
                    style="@style/request_edit" />
            </TableRow>

        </TableLayout>
    </ScrollView>
</LinearLayout>
